# unifi-reconciler local env — copy to `.env` and fill in, then `source .env` before
# running `make plan` / `make apply` / `make export`. (`.env` is gitignored;
# never commit real keys or fingerprints.)
#
# The `export` prefix means `source .env` puts these in your shell environment,
# which is where the Makefile targets read them from.

# UDM management IP. Must be an IPv4 ADDRESS, not a hostname — the in-cluster
# NetworkPolicy locks egress to this /32 and the client dials by IP.
export UDM_HOST=192.168.1.1

# ---- auth: v2 cookie+CSRF login ---------------------------------------------
# Local admin username/password for the v2 cookie+CSRF login. Create a dedicated
# LEAST-PRIVILEGE local admin in the UniFi UI. Fill these in yourself.
export UNIFI_USERNAME=replace-me
export UNIFI_PASSWORD=replace-me

# Internal site shortname (usually "default"). Override only if your controller
# uses a different site.
# export UNIFI_SITE=default

# SHA-256 fingerprint of the UDM's self-signed leaf cert (lowercase hex). The
# connection is pinned to this — there is no verify=False path. From
# chart/values.yaml, captured 2026-06-05 (CN=unifi.local, exp 2027-09-10).
# Re-capture with `UNIFI_INSECURE_TLS=1 make introspect` if the cert is regenerated.
export UDM_CA_FINGERPRINT=e4ba2e41f30c6f9d25a5715102dd5835002f552412053c2c141eb0d4598805f8

# ---- first-run fingerprint capture only -------------------------------------
# Leave UDM_CA_FINGERPRINT unset/blank and uncomment this for ONE run to print
# the live fingerprint, then pin it above and re-comment. Never set in-cluster.
# export UNIFI_INSECURE_TLS=1

# Zones you administer the UDM from (comma-separated; default "Internal"). A broad
# BLOCK/REJECT out of one of these is refused as a lockout risk.
# export UNIFI_ADMIN_ZONES=Internal

# Per-request timeout in seconds (optional; default 30).
# export UNIFI_TIMEOUT=30
